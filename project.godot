; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

warnings/check_invalid_track_paths=false
warnings/check_angle_interpolation_type_conflicting=false
compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Mellow Zone"
run/main_scene="uid://dtkhf76oj53cs"
config/features=PackedStringArray("4.6", "Forward Plus")
run/max_fps=60
config/icon="uid://bafwx55qj65xn"

[audio]

buses/default_bus_layout="uid://dvwibohyco07e"

[autoload]

Global="*res://Scripts/Singletons/global.gd"
ItemData="*res://Scripts/Singletons/ItemData.gd"
BossManager="*res://Scripts/Singletons/BossManager.gd"
SkinData="*res://Scripts/Singletons/SkinData.gd"
GameManager="*res://Scripts/Singletons/GameManager.gd"
BiomeManager="*res://Scripts/Singletons/BiomeManager.gd"
DayTimeManager="*res://Scripts/Singletons/DayTimeManager.gd"
LoadManager="*res://Scripts/Singletons/LoadManager.gd"
SaveManager="*uid://dgvmbpww5am"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/window_width_override=854
window/size/window_height_override=480
window/stretch/mode="viewport"
window/stretch/aspect="expand"

[file_customization]

folder_colors={
"res://Scenes/": "green",
"res://Scripts/": "purple"
}

