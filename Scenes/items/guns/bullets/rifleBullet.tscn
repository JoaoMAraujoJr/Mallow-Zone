resource_name = "Rifle Bullet"
script/source = "extends Bullet


func _ready() -> void:
	pass # Replace with function body.

func _physics_process(_delta: float) -> void:
	followTarget()

func set_dir(dirVector:Vector2):
	super(dirVector)
	$Sprite2D.rotate(dir.angle())

func _on_visible_on_screen_notifier_2d_screen_exited() -> void:
	die()

func uponHit():
	die()

func _on_damage_area_body_entered(body: Node2D) -> void:
	if (body is RigidDamageable or body is CharacterDamageable) and body is not Player :
		body.addToHealth(-damage)
		uponHit()
		return
	if body.has_method(\"setHealth\"):
		body.setHealth(-damage)
		uponHit()
	pass # Replace with function body.
"

