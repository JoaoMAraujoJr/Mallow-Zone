[sub_resource type="GDScript" id="GDScript_nath3"]
resource_name = "lever"
script/source = "extends Control

@export var start_position :float= -30.0
@export var finish_position : float = 156.0
var is_dragging : bool = false
var mouse_on_lever:bool = false
@export var speed : float = 100.0
@onready var lever_area : Button = $lever/lever_area
@onready var lever_visual : Control = $lever

# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	pass # Replace with function body.


# Called every frame. 'delta' is the elapsed time since the previous frame.
func _physics_process(delta: float) -> void:
	if is_dragging :
		lever_visual.position.y = move_toward(lever_visual.position.y,clamp(get_global_mouse_position().y,start_position,finish_position) , delta * speed*1.5)
		print(\"mouse_pos: \", str(get_global_mouse_position().y))
		print(\"lever pos: \", str(lever_visual.position.y))
	else:
		lever_visual.position.y = move_toward(lever_visual.position.y,start_position,delta*speed)

func _input(event: InputEvent) -> void:
	if event.is_action_pressed(\"Mouse_left\") and mouse_on_lever:
		is_dragging = true
	elif event.is_action_released(\"Mouse_left\") or !mouse_on_lever:
		is_dragging = false
	print(\"Dragging :\" , str(is_dragging))
func _on_lever_area_mouse_entered() -> void:
	mouse_on_lever = true
	print(\"mouse on lever\")


func _on_lever_area_mouse_exited() -> void:
	mouse_on_lever = false
	print(\"mouse left lever\")
"

