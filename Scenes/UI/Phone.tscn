[sub_resource type="GDScript" id="GDScript_fdfwi"]
resource_name = "Phone"
script/source = "extends Control # Ou o tipo de nó que o 'Phone' for



func _on_button_1_input_event(camera, event, event_position, normal, shape_idx):
	if event is InputEventMouseButton and event.pressed and event.button_index == MOUSE_BUTTON_LEFT:
		_ao_clicar_no_botao_1()

func _ao_clicar_no_botao_1():
	print(\"Botão 1 pressionado!\")
"

