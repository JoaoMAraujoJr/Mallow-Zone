[sub_resource type="GDScript" id="GDScript_bdx5g"]
resource_name = "dummy_tutorial"
script/source = "extends Sprite2D

@export var particle_scene:PackedScene


func _on_area_2d_area_entered(area: Area2D) -> void:
	if GameManager.currentEquipedWeaponType != \"none\" and GameManager.ammo == 0:
		print(\"loserrr with hard R\")
	var body = area.get_parent()
	if body is Bullet:
		self.visible=false
		$AudioStreamPlayer2D.pitch_scale = randf_range(0.7,1.2)
		$AudioStreamPlayer2D.play()
		if particle_scene:
			var new_explosion = particle_scene.instantiate()
			new_explosion.global_position = global_position
			get_tree().current_scene.add_child(new_explosion)
	await $AudioStreamPlayer2D.finished
	queue_free()
	pass # Replace with function body.
"

