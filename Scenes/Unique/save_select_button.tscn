[sub_resource type="GDScript" id="GDScript_tycyy"]
resource_name = "SaveSelectButton"
script/source = "extends Control

@export var Slot :int = 1
@export var thisSaveFile :SaveFile

func _ready() -> void:
	SaveManager.save_deleted.connect(_upon_display_save_deleted)
	update_button_save_file()
	
func _setSaveFile (save:SaveFile):
	thisSaveFile = save
	if thisSaveFile.cur_skin.animated_icon:
		$\"new_not_empty/player icon/AnimatedSprite2D\".sprite_frames = thisSaveFile.cur_skin.animated_icon
		$\"new_not_empty/player icon/AnimatedSprite2D\".play(\"default\")
	$new_not_empty/labels/last_saved_time/last_saved_time_label.text = get_formatted_datetime(thisSaveFile.last_saved_time)
	$new_not_empty/slot_display.text = \"Save_\"+str(Slot)+\" [img height=14]res://Assets/Textures/UI/game_menu/save_icon.png[/img]\"
	$new_not_empty/hp/hp_amout.text = str(thisSaveFile.cur_hp) +\"|\"+ str(thisSaveFile.max_hp)
	if thisSaveFile.cur_place:
		if thisSaveFile.cur_place.menu_icon:
			$new_not_empty/labels/last_saved_place/last_saved_place_label.text = thisSaveFile.cur_place.display_name + \" [img height=14]\"+ thisSaveFile.cur_place.menu_icon.resource_path  + \"[/img]\"
func set_slot(num: int):
	Slot = num
	update_button_save_file()

func update_button_save_file():
	var path := \"user://saves/save_%d.tres\" % Slot
	if ResourceLoader.exists(path): 
		var loaded_save = ResourceLoader.load(path)
		if loaded_save is SaveFile:
			_setSaveFile(loaded_save)
			$new_areUsure.visible = false
			$new_empty.visible = false
			$new_not_empty.visible = true
	else:
		$new_areUsure.visible = false
		$new_empty.visible = true
		$new_not_empty.visible = false

func _upon_display_save_deleted(slot:int):
	if Slot == slot:
		queue_free()


func get_formatted_datetime(dt:Dictionary) -> String:
	if dt.is_empty() or not dt.has(\"day\"):
		return \"Never Played\" 
	# Formata o dia e mês com 2 dígitos (01, 02...)
	var day = \"%02d\" % dt.day
	var month = \"%02d\" % dt.month
	# Pega os últimos dois dígitos do ano (2026 -> 26)
	var year = str(dt.year).right(2)
	
	# Lógica para converter 24h para 12h (AM/PM)
	var am_pm = \"AM\" if dt.hour < 12 else \"PM\"
	var hour_12 = dt.hour % 12
	if hour_12 == 0: 
		hour_12 = 12 # Ajusta meia-noite e meio-dia
	
	var minute = \"%02d\" % dt.minute
	
	return \"{0}|{1}|{2} {3}:{4} {5}\".format([day, month, year, hour_12, minute, am_pm])


func _on_newgame_pressed() -> void:
	SaveManager.create_new_save(Slot)
	update_button_save_file()
	#GameManager.load_from_current_save()
	#GameManager.canPause = true
	#LoadManager.LoadScene(\"res://Scenes/stages/tutorial_level.tscn\")
	pass # Replace with function body.


func _on_play_pressed() -> void:
	GameManager.canPause = true
	SaveManager.load_game(Slot)
	GameManager.load_from_current_save()
	LoadManager.LoadScene(SaveManager.current_save.cur_place.level_path)
	pass # Replace with function body.

func _on_delete_save_pressed() -> void:
	SaveManager.delete_save(Slot)

func _on_go_back_pressed() -> void:
	$\"new_areUsure\".visible =false
	$new_not_empty.visible=true
	$\"new_empty\".visible =false

func _on_trash_icon_pressed() -> void:
	$\"new_areUsure\".visible =true
	$new_not_empty.visible=false
	$\"new_empty\".visible =false
	pass # Replace with function body.



func _on_card_mouse_entered() -> void:
	var mouse_pos = get_global_mouse_position()
	var card_rect = $new_not_empty/Panel.get_global_rect()
	
	if card_rect.has_point(mouse_pos):
		if $new_not_empty/select_save.current_animation == \"selected\":
			return
		else:
			$new_not_empty/select_save.play(\"select\")
			await $new_not_empty/select_save.animation_finished
			$new_not_empty/select_save.play_backwards(\"selected\")



func _on_card_mouse_exited() -> void:
	var mouse_pos = get_global_mouse_position()
	var card_rect = $new_not_empty/Panel.get_global_rect()
	
	if not card_rect.has_point(mouse_pos):
		if $new_not_empty/select_save.current_animation == \"selected\":
			$new_not_empty/select_save.play_backwards(\"select\")
		else:
			await $new_not_empty/select_save.animation_finished
			$new_not_empty/select_save.play_backwards(\"select\")
"

