[sub_resource type="GDScript" id="GDScript_mxrxc"]
resource_name = "RohkTheBoulder"
script/source = "extends RigidBoss

@onready var visual : SubViewportContainer = $SubViewportContainer
@onready var playerDetector : Area2D = $\"PlayerDetector Area\"

func _process(delta: float) -> void:
	rotateTowardsPlayer()
	pass


func Die():
	super()
	queue_free()

func rotateTowardsPlayer():
	for body in playerDetector.get_overlapping_bodies():
		if body is Player:
			look_at(body.global_position)
			break
"

