[sub_resource type="GDScript" id="GDScript_sdt5q"]
resource_name = "Zet"
script/source = "extends Node2D


@export var DialogTexts :Array[String]
@export var thisDialogFont : FontFile
@export var dialogLabelSettings : LabelSettings
var timer_to_delete_dialog :Timer

@export var dialogContainer:Control
@onready var textcoolDown

func _ready() -> void:
	timer_to_delete_dialog = Timer.new()
	timer_to_delete_dialog.wait_time = 4.0
	timer_to_delete_dialog.timeout.connect(deleteOldestText_timeout)
	add_child(timer_to_delete_dialog)
	pass

func _process(delta: float) -> void:
	deleteOldTexts()
	pass

func printDialog(text: String) -> void:
	var newbubble := Label.new()
	newbubble.text = text
	newbubble.label_settings = dialogLabelSettings
	newbubble.label_settings.font = thisDialogFont

	dialogContainer.add_child(newbubble)

	# Se realmente quiser garantir que fique no topo
	dialogContainer.move_child(
		newbubble,
		dialogContainer.get_child_count() - 1
	)


func _on_dialogue_entering_area_body_entered(body: Node2D) -> void:
	if body is Player:
		printDialog(DialogTexts[randi_range(0,DialogTexts.size()-1)])
	pass # Replace with function body.

func deleteOldTexts():
	if dialogContainer.get_child_count() > 0 :
		if timer_to_delete_dialog.is_stopped():
			timer_to_delete_dialog.start()


func deleteOldestText_timeout():
	if dialogContainer.get_children(): 
		print(dialogContainer.get_child(0).text + \"deleted\" )
		dialogContainer.get_child(0).queue_free()
"

