[sub_resource type="GDScript" id="GDScript_hw23f"]
resource_name = "cow"
script/source = "extends BasicCreatureEntity

@onready var visuals :Node2D = $Visuals
@onready var AnimPlayer :AnimationPlayer = $Visuals/AnimationPlayer
@onready var AnimTree:AnimationTree = $Visuals/AnimationTree

@export var memory_time:float = 10.0
var memory_timer:Timer
@onready var timer_to_delete_self:Timer = $Timer
@export var Damaged_sprite_list:Array[Texture2D]
@export var meat_explosion_particles_scene :PackedScene
@onready var body_sprite:Sprite2D=$Visuals/cow_pivot/cow/body
@onready var head_sprite:Sprite2D=$Visuals/cow_pivot/cow/body/head


# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	super()
	memory_timer = Timer.new()
	add_child(memory_timer)
	memory_timer.wait_time = memory_time
	memory_timer.timeout.connect(func():
		cur_Behaviour = Behaviours.WANDER)
	
	pass # Replace with function body.

func uponDamage():
	super()
	cur_Behaviour = Behaviours.SHY
	memory_timer.start()
	UpdateDamagedCowSprite()

func Die():
	super()
	spawnDamageParticles()
	spawnDamageParticles()
	spawnDamageParticles()
	queue_free()

# Called every frame. 'delta' is the elapsed time since the previous frame.
func _physics_process(delta: float) -> void:
	super(delta)
	if linear_velocity != Vector2.ZERO:
		AnimTree[\"parameters/conditions/is_eating\"]=false
		AnimTree[\"parameters/conditions/is_walking\"]=true
		if linear_velocity.x >=0:
			visuals.scale.x = -1
		elif linear_velocity.x <0:
			visuals.scale.x = 1
	else:
		AnimTree[\"parameters/conditions/is_eating\"]=true
		AnimTree[\"parameters/conditions/is_walking\"]=false
	pass
	
func UpdateDamagedCowSprite():
	var health_ratio = float(health) / float(max_health)

	if health_ratio <= 0:
		body_sprite.texture = Damaged_sprite_list[5]
	elif health_ratio < 0.3:
		spawnDamageParticles()
		body_sprite.texture = Damaged_sprite_list[4]
	elif health_ratio < 0.5:
		spawnDamageParticles()
		body_sprite.texture = Damaged_sprite_list[3]
	elif health_ratio < 0.6:
		spawnDamageParticles()
		body_sprite.texture = Damaged_sprite_list[2]
	elif health_ratio < 0.8:
		spawnDamageParticles()
		body_sprite.texture = Damaged_sprite_list[1]
	else:
		spawnDamageParticles()
		body_sprite.texture = Damaged_sprite_list[0]



func spawnDamageParticles():
	if meat_explosion_particles_scene:
		var part :Node2D= meat_explosion_particles_scene.instantiate()
		part.global_position = body_sprite.global_position
		get_tree().current_scene.add_child(part)


func _exited_screen() -> void:
	print(\"timer to delete cow started\")
	timer_to_delete_self.start()

func _entered_screen() -> void:
	print(\"timer to delete cow stoped\")
	timer_to_delete_self.stop()


func _on_timer_timeout() -> void:
	print(\"CoW Deleted\")
	queue_free()
	pass # Replace with function body.
"

